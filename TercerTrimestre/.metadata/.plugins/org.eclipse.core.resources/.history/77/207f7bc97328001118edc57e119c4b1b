package Ejercicio06;

import java.math.BigDecimal;

public class Persona {

	private String genero;
	private BigDecimal altura;

	public String getGenero() {
		return genero;
	}

	public void setGenero(String genero) throws ParametroIncorrectoException {
		if (!genero.equalsIgnoreCase("h") || !genero.equalsIgnoreCase("m")) {
			throw new ParametroIncorrectoException("Tiene que empezar por H o M Peruanito!!!");
		}

	}

	public BigDecimal getAltura() {
		return altura;
	}

	public void setAltura(BigDecimal altura) throws ParametroIncorrectoException {
		if (altura.compareTo(BigDecimal.ZERO) < 0 || altura.compareTo(new BigDecimal(3)) > 0) {
			throw new ParametroIncorrectoException("Tiene que estar entre 0 y 3 Peruanito!!!");
		}

	}

	@Override
	public String toString() {
		return "Persona [genero=" + genero + ", altura=" + altura + ", getClass()=" + getClass() + ", hashCode()="
				+ hashCode() + ", toString()=" + super.toString() + "]";
	}

}
