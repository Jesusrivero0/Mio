package Ejercicio05;

import java.math.BigDecimal;
import java.util.ArrayList;
import java.util.List;

public class SacoNumero {

	private List<Integer> listaNumeros;

	public SacoNumero() {
		listaNumeros = new ArrayList<>();
	}

	public List<Integer> getListaNumeros() {
		return listaNumeros;
	}

	public void setListaNumeros(List<Integer> listaNumeros) {
		this.listaNumeros = listaNumeros;
	}

	public void addNumero(Integer numero) {
		listaNumeros.add(numero);
	}

	public Integer getNumero(Integer numero) {
		return numero;
	}
	
	public BigDecimal division() {
		Integer total = 0;
		Integer pocision = listaNumeros.get(0);
		for (Integer i : listaNumeros) {
			total = listaNumeros.get(pocision)/(listaNumeros.get(i));
		}
	}

	@Override
	public String toString() {
		return "SacoNumero listaNumeros=" + listaNumeros;
	}

}
