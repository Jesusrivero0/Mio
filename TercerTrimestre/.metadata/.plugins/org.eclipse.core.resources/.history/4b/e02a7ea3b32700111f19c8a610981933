package Ejercicio05;

import java.util.InputMismatchException;
import java.util.Scanner;

public class App {

	public static void main(String[] args) {
		Scanner scanner = new Scanner(System.in);
		int num = 0;
		int pos = 0;
		SacoNumero s = new SacoNumero();
		try {

			do {
				try {
					System.out.println("Indica numeros");
					num = scanner.nextInt();
					if (num != -1) {
						s.addNumero(num);
					}
				} catch (InputMismatchException e) {
					System.out.println("no puedes meter letras peruanoooo!!!!");
				}
			} while (num != -1);
			System.out.println(s.getListaNumeros());

			do {
				try {
					System.out.println("Indica con un numero la pocision que quieres ver");
					pos = scanner.nextInt();
					System.out.println(s.getListaNumeros().get(pos));
				} catch (IndexOutOfBoundsException i) {
					System.out.println("No existe esa pocision peruano");
				}
			} while (pos != -1);

		} finally {
			scanner.close();
		}

	}

}
